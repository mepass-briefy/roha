# 환경변수 예시 파일. 실제 값은 .env(.gitignore 등록)에만 두고, 이 파일엔 형식만 둔다.
# 실제 키·연결문자열을 이 파일에 넣지 말 것(커밋되는 파일).
#
# 사용법(예):
#   cp .env.example .env  후 실제 값 입력
#   PowerShell:  $env:ANTHROPIC_API_KEY = "sk-ant-..."
#   bash:        export ANTHROPIC_API_KEY="sk-ant-..."
#   real 실행:   STRATEGY_MODE=real python agents/demo_strategy.py
#   DB 적용:     python db/setup_db.py  (roha/.env 의 DATABASE_URL 사용)

# Strategy Agent real 모드(Anthropic messages API)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# DB(DDL v2) 적용용 Neon PostgreSQL 연결 문자열
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
