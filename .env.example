# Strategy Agent real 모드용 환경변수 예시.
# 실제 .env 파일은 커밋하지 않는다(.gitignore에 등록됨). 키를 코드에 박지 말 것.
#
# 사용법(예):
#   cp .env.example .env  후 키 입력, 또는 셸에서 직접 export
#   PowerShell:  $env:ANTHROPIC_API_KEY = "sk-ant-..."
#   bash:        export ANTHROPIC_API_KEY="sk-ant-..."
#   real 실행:   STRATEGY_MODE=real python agents/demo_strategy.py

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
